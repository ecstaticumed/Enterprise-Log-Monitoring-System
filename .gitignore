###############################################################################
# Enterprise Log Monitoring System
# Professional .gitignore
###############################################################################

###############################################################################
# Python
###############################################################################

__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

###############################################################################
# Virtual Environment
###############################################################################

venv/
.venv/
env/
ENV/

###############################################################################
# Environment Variables / Secrets
###############################################################################

.env
.env.*
*.env

###############################################################################
# IDEs
###############################################################################

.vscode/
.idea/

###############################################################################
# Operating System Files
###############################################################################

.DS_Store
Thumbs.db
Desktop.ini

###############################################################################
# Python Packaging
###############################################################################

build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

###############################################################################
# Logs
###############################################################################

logs/
*.log
*.out
*.err

###############################################################################
# Temporary Files
###############################################################################

*.tmp
*.temp
*.bak
*.swp
*.swo
*~

###############################################################################
# Reports (Generated)
###############################################################################

reports/*.csv
reports/*.json
reports/*.html
reports/*.pdf

###############################################################################
# Screenshots (Optional)
# Remove this section if you want to upload screenshots.
###############################################################################

screenshots/raw/

###############################################################################
# Wazuh
###############################################################################

*.wpk
*.db
*.sqlite
*.sqlite3

###############################################################################
# API Keys & Certificates
###############################################################################

*.key
*.pem
*.crt
*.csr
*.pfx
*.p12

###############################################################################
# Backup Files
###############################################################################

*.zip
*.tar
*.gz
*.7z
*.rar

###############################################################################
# Jupyter
###############################################################################

.ipynb_checkpoints/

###############################################################################
# Testing
###############################################################################

.pytest_cache/
.coverage
htmlcov/

###############################################################################
# Local Configuration
###############################################################################

config.local.py
config.dev.py
config.private.py

###############################################################################
# Terraform (Future Cloud Projects)
###############################################################################

.terraform/
*.tfstate
*.tfstate.*

###############################################################################
# Docker (Future)
###############################################################################

docker-compose.override.yml

###############################################################################
# Node.js (Future Dashboard Development)
###############################################################################

node_modules/
npm-debug.log*

###############################################################################
# macOS
###############################################################################

.AppleDouble
.LSOverride

###############################################################################
# Windows
###############################################################################

$RECYCLE.BIN/

###############################################################################
# Linux
###############################################################################

*~

###############################################################################
# Keep Important Directories
###############################################################################

!architecture/
!dashboards/
!detection-rules/
!attack-scenarios/
!docs/
!assets/
!screenshots/
